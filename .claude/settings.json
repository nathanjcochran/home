{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(errcheck:*)",
      "Bash(find:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go fmt:*)",
      "Bash(go generate:*)",
      "Bash(go get:*)",
      "Bash(go install:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(go tool:*)",
      "Bash(go vet:*)",
      "Bash(gopls rename:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(open:*)",
      "Bash(shellcheck:*)",
      "Bash(staticcheck:*)",
      "Bash(wc:*)",
      "Read(~/go/pkg/mod/**)",
      "Read(~/src/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "deny": [
      "EnterPlanMode"
    ],
    "ask": [
      "Bash(gh release create:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": false
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high"
}
